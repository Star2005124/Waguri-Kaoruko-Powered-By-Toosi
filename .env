# ╔══════════════════════════════════════════════╗
# ║         TOOSII-XD ULTRA  —  .env Config       ║
# ║   Fill in the required values below and save  ║
# ╚══════════════════════════════════════════════╝

# ─── REQUIRED ─────────────────────────────────────────────────────────────────

# Your WhatsApp number with country code — no + or spaces
# Example: 254748340864 (Kenya)  |  2348012345678 (Nigeria)  |  12025551234 (US)
OWNER_NUMBER=254788781373

# Session ID generated from the Session Generator (option 2 at the terminal)
# Get yours at: https://toosii-xd-session-generator-woyo.onrender.com/pair
# Format must start with TOOSII~
SESSION_ID=TOOSII~

# URL shown in .owner command and .botinfo output
SESSION_URL=https://toosii-xd-session-generator-woyo.onrender.com/pair

# ─── OPTIONAL — AI KEYS ───────────────────────────────────────────────────────
# The bot works WITHOUT these — GiftedTech + Pollinations are used by default.
# Add them only if you want additional AI model access.

# Anthropic Claude (optional — enables .claudeai fallback)
# ANTHROPIC_API_KEY=sk-ant-...

# ─── OPTIONAL — IMAGE / MEDIA KEYS ───────────────────────────────────────────
# The bot has free fallbacks for all of these.

# remove.bg API key (optional — improves .removebg quality)
# REMOVEBG_KEY=your_removebg_key_here

# Clipdrop API key (optional — extra fallback for background removal)
# CLIPDROP_KEY=your_clipdrop_key_here

# ─── OPTIONAL — BOT BEHAVIOUR ─────────────────────────────────────────────────
# These override defaults without touching setting.js
# Uncomment and set as needed.

# Bot display name (default: TOOSII-XD ULTRA)
# BOT_NAME=TOOSII-XD ULTRA

# Bot prefix — default is dot (.)
# PREFIX=.
