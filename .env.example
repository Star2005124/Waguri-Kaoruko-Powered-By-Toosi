# ─────────────────────────────────────────────────────────────────────────────
# TOOSII-XD ULTRA — Environment Variables
# Copy this file to .env and fill in your own values.
# ─────────────────────────────────────────────────────────────────────────────

# Your WhatsApp number with country code, no + or leading 0
# Example Kenya: 254748340864   Nigeria: 2348012345678   US: 12025551234
OWNER_NUMBER=254748340864

# SESSION_ID — generated by the session generator (/pair or /qr)
# Format: TOOSII~<base64>
# Leave blank to use interactive terminal pairing on first run
SESSION_ID=

# (Optional) URL of your own session generator deployment.
# Shown in the bot's connection message so users know where to get a session.
# If left blank the default public generator is used.
SESSION_URL=
